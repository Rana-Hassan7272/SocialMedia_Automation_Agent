# ========================================
# LLM — Google Gemini (primary)
# ========================================
GOOGLE_API_KEY=
GOOGLE_GEMINI_MODEL=gemini-3.1-flash-lite

# ========================================
# LLM — Groq (fallback when Gemini limit/fails)
# ========================================
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# ========================================
# Neon PostgreSQL (required for production)
# ========================================
# From Neon dashboard: Connection string (pooled recommended)
# Example: postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=

# Local dev fallback only (used when DATABASE_URL is empty)
DATABASE_PATH=data/social_automation.db

# ========================================
# X OAuth 2.0 (required for Streamlit app)
# ========================================
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=
# Local: http://localhost:8501
# Streamlit Cloud: https://your-app-name.streamlit.app
TWITTER_CALLBACK_URL=http://localhost:8501

# Generate: python generate_encryption_key.py
ENCRYPTION_KEY=

# ========================================
# Legacy single-account X keys (optional CLI demos)
# ========================================
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=

# ========================================
# Application Settings
# ========================================
LOG_LEVEL=INFO
MAX_TWEETS_PER_QUERY=50
MIN_ENGAGEMENT_SCORE=10
TOP_TWEETS_COUNT=8
MAX_WORKFLOWS_PER_USER_PER_DAY=20
MAX_LLM_CALLS_PER_USER_PER_DAY=50
MAX_PUBLISH_PER_USER_PER_DAY=10
REDDIT_USER_AGENT=windows:SocialPulse:v1.0 (by /u/your_reddit_username)
# Free: https://www.reddit.com/prefs/apps → create "script" app
# redirect uri (required by Reddit UI): http://localhost:8501
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
